{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Статья"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "content_html": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "articles"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "articles"
    },
    "region": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::region.region",
      "inversedBy": "articles"
    },
    "sections": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::section.section",
      "inversedBy": "articles"
    },
    "section_tree": {
      "type": "customField",
      "customField": "plugin::section-tree.section-tree-field"
    },
    "format": {
      "type": "enumeration",
      "required": true,
      "default": "анализ",
      "enum": [
        "анализ",
        "мнение",
        "интервью",
        "колонка",
        "обзор"
      ]
    },
    "is_global_review": {
      "type": "boolean",
      "default": false
    },
    "views_count": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "reading_time": {
      "type": "integer",
      "min": 0
    },
    "publication_date": {
      "type": "datetime"
    },
    "telegram_message_id": {
      "type": "biginteger"
    },
    "content": {
      "type": "blocks"
    }
  }
}
