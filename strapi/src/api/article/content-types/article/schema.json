{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Статья"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "content": {
      "type": "blocks"
    },
    "excerpt": {
      "type": "text",
      "maxLength": 300
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "articles"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "articles",
      "description": "Тематические теги (можно несколько)"
    },
    "region": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::region.region",
      "inversedBy": "articles",
      "description": "Основной макрорегион статьи (один)"
    },
    "sections": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::section.section",
      "inversedBy": "articles",
      "description": "Разделы сайта. Удобный выбор — панель «Классификация (дерево разделов)» справа; это поле можно сжать или скрыть в «Настроить вид»"
    },
    "format": {
      "type": "enumeration",
      "enum": ["анализ", "мнение", "интервью", "колонка", "обзор"],
      "required": true,
      "default": "анализ",
      "description": "Тип материала"
    },
    "is_global_review": {
      "type": "boolean",
      "default": false,
      "description": "TRUE если это ежемесячный глобальный обзор"
    },
    "views_count": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "reading_time": {
      "type": "integer",
      "min": 0
    },
    "publication_date": {
      "type": "datetime",
      "description": "Дата публикации на сайте (не путать с системным published_at Strapi при D&P)"
    },
    "telegram_message_id": {
      "type": "biginteger"
    }
  }
}
