# Server
HOST=0.0.0.0
PORT=1337

# Secrets (generate new for production)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=changeme
ADMIN_JWT_SECRET=changeme
TRANSFER_TOKEN_SALT=changeme
ENCRYPTION_KEY=changeme
JWT_SECRET=changeme

# Database — PostgreSQL
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false
# Optional: DATABASE_URL=postgresql://strapi:strapi@127.0.0.1:5432/strapi

# Upload cache (seconds)
UPLOAD_MAX_AGE=300000
