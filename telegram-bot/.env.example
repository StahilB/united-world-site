# Telegram Bot API token from @BotFather
BOT_TOKEN=

# Target channel ID (e.g. -1001234567890 for supergroups/channels)
CHANNEL_ID=

# Strapi base URL (no trailing slash)
STRAPI_URL=http://localhost:1337

# Strapi API token (Settings → API Tokens) with create/update for articles, authors, upload
STRAPI_TOKEN=

# Public site URL for success messages (no trailing slash)
SITE_URL=http://localhost:3000

# Shared secret for Next.js on-demand revalidation endpoint
REVALIDATE_SECRET=
