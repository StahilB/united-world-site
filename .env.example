# --- PostgreSQL (docker-compose service `postgres`) ---
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=change_me_strong_password

# --- Strapi secrets (generate random strings for production) ---
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=change_me
ADMIN_JWT_SECRET=change_me
JWT_SECRET=change_me
TRANSFER_TOKEN_SALT=change_me

# --- Strapi URL visible in the browser (media, client). Must NOT be localhost in production. ---
# Option A — direct port: NEXT_PUBLIC_STRAPI_URL=http://85.239.42.204:1337
# Option B — same host as the site with nginx /uploads/ → Strapi: NEXT_PUBLIC_STRAPI_URL=https://anounitedworld.com
# Docker: all NEXT_PUBLIC_* must be in .env when you run `docker compose build nextjs` — they are baked into the client bundle at build time.
NEXT_PUBLIC_STRAPI_URL=https://admin.anounitedworld.com

# --- Internal Strapi URL inside Docker network (server-side Next.js fetch) ---
STRAPI_URL=http://strapi:1337

# --- Strapi API token for Next.js (optional: article views, server actions) ---
STRAPI_TOKEN=

# --- Telegram bot ---
BOT_TOKEN=
CHANNEL_ID=

# --- Public site URL (success links from bot) ---
SITE_URL=https://anounitedworld.com
NEXT_PUBLIC_SITE_URL=https://anounitedworld.com
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_MAILRU_VERIFICATION=
NEXT_PUBLIC_YANDEX_METRICA_ID=
NEXT_PUBLIC_YM_WEBVISOR=true
REVALIDATE_SECRET=

# --- Mascot «Мудрый Кот» (AI assistant, /api/mascot/chat) ---
# Провайдер: gigachat | yandex | openai | anthropic (для РФ обычно gigachat или yandex)
MASCOT_PROVIDER=gigachat
ANTHROPIC_API_KEY=
MASCOT_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
MASCOT_OPENAI_MODEL=gpt-5-mini
# GigaChat: ключ Authorization (Base64) из https://developers.sber.ru/gigachat
GIGACHAT_AUTHORIZATION_KEY=
# GIGACHAT_API_PERS — физлица; для юрлиц часто GIGACHAT_API_CORP
GIGACHAT_OAUTH_SCOPE=GIGACHAT_API_PERS
MASCOT_GIGACHAT_MODEL=GigaChat
# Только временный обход при проблемах с доверием к цепочке TLS в контейнере; предпочтительно российские CA в Docker-образе
GIGACHAT_ALLOW_INSECURE_SSL=false
# Yandex Foundation Models (консоль cloud.yandex.ru)
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_FOLDER_ID=
MASCOT_YANDEX_MODEL_URI=
MASCOT_MAX_TOKENS=500
MASCOT_RATE_LIMIT_PER_MIN=10

# --- WordPress migration (migration/migrate.js) ---
# WP_BASE_URL=https://anounitedworld.com
# STRAPI_TOKEN must allow create on articles, authors, upload
