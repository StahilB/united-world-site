# --- PostgreSQL (docker-compose service `postgres`) ---
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=change_me_strong_password

# --- Strapi secrets (generate random strings for production) ---
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=change_me
ADMIN_JWT_SECRET=change_me
JWT_SECRET=change_me
TRANSFER_TOKEN_SALT=change_me

# --- Strapi / Next public API URL (browser). Use https://admin.yourdomain.com in production. ---
NEXT_PUBLIC_STRAPI_URL=https://admin.anounitedworld.com

# --- Internal Strapi URL inside Docker network (server-side Next.js fetch) ---
STRAPI_URL=http://strapi:1337

# --- Strapi API token for Next.js (optional: article views, server actions) ---
STRAPI_TOKEN=

# --- Telegram bot ---
BOT_TOKEN=
CHANNEL_ID=

# --- Public site URL (success links from bot) ---
SITE_URL=https://anounitedworld.com
